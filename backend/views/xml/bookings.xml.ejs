<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bookings [
<!ELEMENT bookings (booking*)>
    <!ATTLIST bookings member CDATA "">
    <!ATTLIST bookings export-date CDATA "0000-00-00">
    <!ELEMENT booking (activity, location, date, time)>
    <!ATTLIST booking Id CDATA "">
    <!ELEMENT activity (#PCDATA)>
    <!ELEMENT location (#PCDATA)>
    <!ELEMENT date (#PCDATA)>
    <!ELEMENT time (#PCDATA)>
]>

<bookings member="<%= name %>" export-date="<%= exportDate %>" >
  <%  for (const {booking, session, activity, location} of bookings) { %>

  <booking Id="<%= booking.id %>">
    <activity><%= activity.name %></activity>
    <location><%= location.name %></location>
    <date><%= session.date %></date>
    <time><%= session.startTime %></time>
  </booking>
  
  <% } %>

</bookings>